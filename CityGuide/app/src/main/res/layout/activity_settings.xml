<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/city_surface"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/city_primary"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="Настройки"
        app:titleTextColor="@color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <CheckBox
            android:id="@+id/notificationsCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Напоминать о местах" />

        <CheckBox
            android:id="@+id/showVisitedCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Показывать посещённые места" />

        <TextView
            android:id="@+id/settingsStatusTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/city_text_secondary" />

        <Button
            android:id="@+id/saveSettingsButton"
            style="@style/CityButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Сохранить настройки" />
    </LinearLayout>
</LinearLayout>
